# VeloRoute Vientiane: Git ignore rules

# Node dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build outputs
dist/
build/

# Python caching & Virtual Environments
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
env/
.pytest_cache/

# IDE & Editor configs
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Local system files
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# Environment variables
.env
.env.local
.env.*.local
